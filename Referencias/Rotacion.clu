O = e1 + 2*e2 + 3*e3 + einf; //Objeto a trasladar (plano)

x=Slider("x",-5,5,0.1,0);
y=Slider("y",-5,5,0.1,0);
z=Slider("z",-5,5,0.1,0);

?t = x*e1 + y*e2 + z*e3;
