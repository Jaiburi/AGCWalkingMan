DefVarsN3();
DrawFrame(0.5,"axes");

//TRANSFORMACIONES

// Rotación Rotor R
//*
:IPNS;
O = VecN3(1,0,0) - 1/2*(0.5)^^2*einf; //Objeto a rotar (esfera)
O = (e0^VecN3(1,0,0)^VecN3(0,1,0))*; //Objeto a rotar (circulo)

th = Slider("Ángulo",0, 2*Pi, 0.05,0); //Angulo de rotación
v = e1 - e3; //Eje de rotación (vector)
B = -v*(e1*e2*e3)/abs(v); //Bivector (eje de rotación)
?R = cos(th/2) + sin(th/2)*B; //Rotor
:R = RotorN3(v,th); //Rotor con función
?Op = R*O*(~R); //Objeto a rotar

:White;
:O;
:Cyan;
:Op;
//*/

// Traslación
