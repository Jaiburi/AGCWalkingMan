:Cyan;
:Op;
//*/

// Motor (Trasladar y luego rotar)
// Ejemplo: péndulo simple
//*
:IPNS;
O = e0; //Centro de esfera (Masa del pendulo)
L = 1; //Longitud del péndulo
//th = Slider("Ángulo",0,2*Pi),0.05,0);
check = CheckBox("Animación", false);
EnableAnimate(check);
?t = Time%20;
?th = Pi/2*cos(3*t)*exp(-0.2*t);
//Angulo oscilante y decreciente del pendulo

R = RotorN3(0,0,1,th);
T = TranslatorN3(0,-L,0);
M = R*T;
Op = M*O*(~M);

:White;
:Op-1/2*(0.3)^^2*einf;
:Yellow;
DrawCylinder(O,Op,0.05); //Dibuja cilindro
//:DrawCylinder(Punto inicial del clilindro, Op, 0.05)









